    { "id": "q_missing_identifying", "group": "missing_person", "order": 740, "label_he": "פרטים מזהים של הנעדר — מגדר, גובה, היכן שהה", "type": "open_text", "required": false, "category": "bereavement" },

    { "id": "q_worker_impression", "group": "worker_summary", "order": 800, "label_he": "התרשמות אישית של ממלא השאלון — מאפיינים / כוחות / קשיים שחשובים בהמשך לצורך ליווי והיערכות", "type": "open_text", "required": true, "category": "functional_routine" },
    { "id": "q_worker_name_role", "group": "worker_summary", "order": 810, "label_he": "שם ממלא הטופס ותפקידו", "type": "open_text", "required": true, "category": "functional_routine" },
